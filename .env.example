# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-secret-key

# Database
DATABASE_URL=sqlite:///skillswap.db
DB_POOL_SIZE=1
DB_MAX_OVERFLOW=1
DB_POOL_TIMEOUT=15

# Uploads
UPLOAD_FOLDER=skillswap/static/uploads/avatars
MAX_CONTENT_LENGTH=5242880

# Security
WTF_CSRF_ENABLED=True

# Render / deployment
WEB_CONCURRENCY=1
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_KEEPALIVE=5
AUTO_DB_INIT=1
LIGHTWEIGHT_LANDING=1
ENABLE_REALTIME=0
FAST_DASHBOARD=1
SEND_FILE_MAX_AGE_DEFAULT=2592000

# Cache
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300

# Email provider
# Local development can use smtp. Render Free should use resend.
EMAIL_PROVIDER=smtp
BASE_URL=http://127.0.0.1:5000

# Gmail SMTP for local development only
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USE_TLS=0
MAIL_USE_SSL=1
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-google-app-password
MAIL_DEFAULT_SENDER=your-gmail@gmail.com

# Resend for Render Free
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=onboarding@resend.dev
